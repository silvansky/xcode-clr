#!/usr/bin/python3
"""xcode-clr — list & delete stale Xcode DerivedData and worktree build/ dirs."""
from __future__ import annotations

import argparse
import json
import os
import plistlib
import shutil
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

DERIVED_DATA = Path.home() / "Library/Developer/Xcode/DerivedData"
CONFIG_PATH = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "xcode-clr/config.json"
SKIP_DD_NAMES = {"ModuleCache.noindex", "SDKStatCaches.noindex", "CompilationCache.noindex"}


@dataclass
class Entry:
    path: Path
    kind: str  # "derived_data" | "worktree_build" | "simulator"
    source_path: Optional[Path]
    mtime: datetime
    last_accessed: Optional[datetime] = None
    size_bytes: int = 0
    reason: Optional[str] = None
    udid: Optional[str] = None       # simulator only
    state: Optional[str] = None      # simulator only: Booted | Shutdown | ...
    available: bool = True           # simulator only: runtime still installed
    label: Optional[str] = None      # display name shown instead of source_path

    @property
    def staleness_ts(self) -> datetime:
        if self.kind == "simulator":
            return self.last_accessed or self.mtime  # last boot, else folder mtime
        return max(self.mtime, self.last_accessed) if self.last_accessed else self.mtime

    def age_days(self, now: datetime) -> float:
        return (now - self.staleness_ts).total_seconds() / 86400.0


def find_derived_data() -> list[Entry]:
    if not DERIVED_DATA.is_dir():
        return []
    entries: list[Entry] = []
    for child in DERIVED_DATA.iterdir():
        if not child.is_dir() or child.name in SKIP_DD_NAMES or child.name.endswith(".noindex"):
            continue
        plist = child / "info.plist"
        if not plist.is_file():
            continue
        try:
            with plist.open("rb") as f:
                data = plistlib.load(f)
        except Exception:
            continue
        workspace = data.get("WorkspacePath")
        if not workspace:
            continue
        last_accessed = data.get("LastAccessedDate")
        if isinstance(last_accessed, datetime) and last_accessed.tzinfo is None:
            last_accessed = last_accessed.replace(tzinfo=timezone.utc)
        mtime = datetime.fromtimestamp(child.stat().st_mtime, tz=timezone.utc)
        entries.append(Entry(
            path=child,
            kind="derived_data",
            source_path=Path(workspace),
            mtime=mtime,
            last_accessed=last_accessed,
        ))
    return entries


def git_worktree_paths(root: Path) -> list[Path]:
    if not root.is_dir():
        return []
    try:
        out = subprocess.run(
            ["git", "-C", str(root), "worktree", "list", "--porcelain"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []
    paths: list[Path] = []
    for line in out.splitlines():
        if line.startswith("worktree "):
            paths.append(Path(line[len("worktree "):]))
    return paths


def find_git_root(start: Path) -> Optional[Path]:
    for p in [start, *start.parents]:
        if (p / ".git").exists():
            return p
    return None


def resolve_worktree_roots(
    derived: list[Entry],
    explicit: list[Path],
    auto: bool,
) -> list[Path]:
    seen: set[Path] = set()
    roots: list[Path] = []

    def add(p: Path) -> None:
        try:
            r = p.resolve()
        except OSError:
            return
        if r in seen or not r.is_dir():
            return
        seen.add(r)
        roots.append(r)

    for p in explicit:
        add(p)
    if auto:
        for e in derived:
            if e.source_path and e.source_path.exists():
                gr = find_git_root(e.source_path.parent)
                if gr:
                    add(gr)
    return roots


def find_stale_builds(worktree_roots: list[Path]) -> list[Entry]:
    seen: set[Path] = set()
    entries: list[Entry] = []
    for root in worktree_roots:
        for wt in git_worktree_paths(root):
            try:
                wt_resolved = wt.resolve()
            except OSError:
                continue
            if wt_resolved in seen:
                continue
            seen.add(wt_resolved)
            build = wt / "build"
            if not build.is_dir():
                continue
            mtime = datetime.fromtimestamp(build.stat().st_mtime, tz=timezone.utc)
            entries.append(Entry(
                path=build,
                kind="worktree_build",
                source_path=wt,
                mtime=mtime,
            ))
    return entries


def parse_iso(s: Optional[str]) -> Optional[datetime]:
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00"))
    except ValueError:
        return None


def runtime_label(runtime_id: str) -> str:
    tail = runtime_id.rsplit(".", 1)[-1]  # iOS-18-6
    parts = tail.split("-")
    return f"{parts[0]} {'.'.join(parts[1:])}" if len(parts) > 1 else tail


def simctl_devices() -> dict:
    try:
        out = subprocess.run(
            ["xcrun", "simctl", "list", "devices", "--json"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return {}
    try:
        return json.loads(out).get("devices", {})
    except ValueError:
        return {}


def find_simulators() -> list[Entry]:
    entries: list[Entry] = []
    for runtime_id, devices in simctl_devices().items():
        rt = runtime_label(runtime_id)
        for d in devices:
            udid, data_path = d.get("udid"), d.get("dataPath")
            if not udid or not data_path:
                continue
            device_dir = Path(data_path).parent
            last_booted = parse_iso(d.get("lastBootedAt"))
            try:
                mtime = datetime.fromtimestamp(device_dir.stat().st_mtime, tz=timezone.utc)
            except OSError:
                if last_booted is None:
                    continue
                mtime = last_booted
            state = d.get("state")
            name = d.get("name") or udid
            tags = [t for t in (rt, None if state == "Shutdown" else state) if t]
            entries.append(Entry(
                path=device_dir,
                kind="simulator",
                source_path=None,
                mtime=mtime,
                last_accessed=last_booted,
                size_bytes=int(d.get("dataPathSize") or 0),
                udid=udid,
                state=state,
                available=bool(d.get("isAvailable")),
                label=f"{name} · {' · '.join(tags)}",
            ))
    return entries


def mark_stale(entries: list[Entry], days: int, sim_days: int, now: datetime) -> None:
    for e in entries:
        if e.kind == "simulator":
            if not e.available:
                e.reason = "runtime unavailable"
            elif e.state != "Shutdown":
                pass  # booted / in use — never delete
            elif e.last_accessed is None:
                pass  # never booted — leave default templates alone
            elif e.age_days(now) > sim_days:
                e.reason = f"stale >{sim_days}d"
            continue
        if e.kind == "derived_data" and e.source_path and not e.source_path.exists():
            e.reason = "source missing"
            continue
        if e.age_days(now) > days:
            e.reason = f"stale >{days}d"


def du_bytes(path: Path) -> int:
    try:
        out = subprocess.run(
            ["du", "-sk", str(path)],
            capture_output=True, text=True, check=True,
        ).stdout
    except subprocess.CalledProcessError:
        return 0
    try:
        return int(out.split()[0]) * 1024
    except (ValueError, IndexError):
        return 0


def compute_sizes(entries: list[Entry]) -> None:
    todo = [e for e in entries if not e.size_bytes]  # simulators carry dataPathSize already
    if not todo:
        return
    with ThreadPoolExecutor(max_workers=8) as ex:
        sizes = list(ex.map(du_bytes, [e.path for e in todo]))
    for e, s in zip(todo, sizes):
        e.size_bytes = s


def human_size(n: int) -> str:
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024 or unit == "TB":
            return f"{n:.1f} {unit}" if unit != "B" else f"{n} B"
        n /= 1024
    return f"{n:.1f} TB"


def truncate_left(s: str, width: int) -> str:
    if len(s) <= width:
        return s
    return "..." + s[-(width - 3):]


def short_path(p: Optional[Path]) -> str:
    if p is None:
        return "-"
    s = str(p)
    home = str(Path.home())
    if s.startswith(home):
        s = "~" + s[len(home):]
    return s


def render_table(entries: list[Entry], now: datetime, numbered: bool = False) -> str:
    if not entries:
        return ""
    header = ("SIZE", "AGE", "REASON", "KIND", "SOURCE", "PATH")
    rows = [(("#",) + header) if numbered else header]
    for i, e in enumerate(entries, 1):
        row = (
            human_size(e.size_bytes),
            f"{e.age_days(now):.1f}d",
            e.reason or "-",
            e.kind,
            truncate_left(e.label or short_path(e.source_path), 70),
            truncate_left(short_path(e.path), 70),
        )
        rows.append(((str(i),) + row) if numbered else row)
    widths = [max(len(r[i]) for r in rows) for i in range(len(rows[0]))]
    lines = []
    for r in rows:
        lines.append("  ".join(c.ljust(widths[i]) for i, c in enumerate(r)))
    return "\n".join(lines)


def disk_usage() -> tuple[int, int]:
    u = shutil.disk_usage(Path.home())
    return u.free, u.total


def render_json(entries: list[Entry], threshold_days: int, sim_threshold_days: int, now: datetime) -> str:
    def iso(dt: Optional[datetime]) -> Optional[str]:
        return dt.astimezone(timezone.utc).isoformat().replace("+00:00", "Z") if dt else None

    items = []
    for e in entries:
        item = {
            "path": str(e.path),
            "kind": e.kind,
            "source_path": str(e.source_path) if e.source_path else None,
            "size_bytes": e.size_bytes,
            "last_accessed": iso(e.last_accessed),
            "mtime": iso(e.mtime),
            "age_days": round(e.age_days(now), 2),
            "reason": e.reason,
            "to_be_removed": e.reason is not None,
        }
        if e.kind == "simulator":
            item.update(name=e.label, udid=e.udid, state=e.state, available=e.available)
        items.append(item)
    free, total = disk_usage()
    return json.dumps({
        "scanned_at": iso(now),
        "threshold_days": threshold_days,
        "simulator_threshold_days": sim_threshold_days,
        "disk": {"free_bytes": free, "total_bytes": total, "used_bytes": total - free},
        "items": items,
    }, indent=2)


def parse_selection(s: str, n: int) -> Optional[set[int]]:
    """Parse "1,3,5-7" into a set of 0-based indices in [0, n). None on syntax error."""
    out: set[int] = set()
    for tok in s.replace(" ", "").split(","):
        if not tok:
            continue
        if "-" in tok:
            a, _, b = tok.partition("-")
            if not (a.isdigit() and b.isdigit()):
                return None
            lo, hi = sorted((int(a), int(b)))
        elif tok.isdigit():
            lo = hi = int(tok)
        else:
            return None
        out.update(i - 1 for i in range(lo, hi + 1) if 1 <= i <= n)
    return out


def delete_entries(entries: list[Entry]) -> int:
    freed = 0
    for e in entries:
        try:
            if e.kind == "simulator":
                r = subprocess.run(
                    ["xcrun", "simctl", "delete", e.udid],
                    capture_output=True, text=True,
                )
                if r.returncode != 0:
                    raise RuntimeError(r.stderr.strip() or f"simctl exit {r.returncode}")
            else:
                shutil.rmtree(e.path)
            freed += e.size_bytes
            print(f"  removed {e.label or e.path} ({human_size(e.size_bytes)})")
        except Exception as ex:
            print(f"  FAILED {e.label or e.path}: {ex}", file=sys.stderr)
    return freed


def load_config() -> dict:
    if not CONFIG_PATH.is_file():
        return {}
    try:
        with CONFIG_PATH.open() as f:
            return json.load(f)
    except (OSError, ValueError) as ex:
        print(f"warning: ignoring {CONFIG_PATH}: {ex}", file=sys.stderr)
        return {}


def env_worktree_roots() -> list[Path]:
    raw = os.environ.get("XCODE_CLR_WORKTREE_ROOTS", "")
    return [Path(p).expanduser() for p in raw.split(":") if p]


def main() -> int:
    cfg = load_config()
    cfg_roots = [Path(p).expanduser() for p in cfg.get("worktree_roots", [])]
    cfg_days = int(cfg.get("threshold_days", 7))
    cfg_auto = bool(cfg.get("auto_discover", True))
    cfg_sims = bool(cfg.get("scan_simulators", True))
    cfg_sim_days = int(cfg.get("simulator_threshold_days", 14))

    p = argparse.ArgumentParser(description="Delete stale Xcode DerivedData and worktree build/ dirs.")
    p.add_argument("--dry-run", action="store_true", help="list only, never delete")
    p.add_argument("--json", action="store_true", help="emit JSON (implies no delete)")
    p.add_argument("--yes", "-y", action="store_true", help="skip confirmation prompt")
    p.add_argument("--days", type=int, default=cfg_days,
                   help=f"staleness threshold in days (default {cfg_days})")
    p.add_argument("--simulator-days", type=int, default=cfg_sim_days,
                   help=f"simulator staleness threshold in days (default {cfg_sim_days})")
    p.add_argument("--worktree-root", type=Path, action="append", default=[],
                   metavar="PATH",
                   help="extra git worktree root to scan; repeatable")
    p.add_argument("--no-auto", dest="auto", action="store_false", default=cfg_auto,
                   help="disable auto-discovery of worktree roots from DerivedData WorkspacePath")
    p.add_argument("--no-simulators", dest="simulators", action="store_false", default=cfg_sims,
                   help="skip scanning iOS Simulator devices")
    p.add_argument("--all", action="store_true", help="list every folder found, not only stale")
    args = p.parse_args()

    now = datetime.now(timezone.utc)
    derived = find_derived_data()
    roots = resolve_worktree_roots(
        derived,
        explicit=cfg_roots + env_worktree_roots() + args.worktree_root,
        auto=args.auto,
    )
    entries = derived + find_stale_builds(roots)
    if args.simulators:
        entries += find_simulators()
    mark_stale(entries, args.days, args.simulator_days, now)
    compute_sizes(entries)
    entries.sort(key=lambda e: (e.reason is None, -e.size_bytes))

    if args.json:
        print(render_json(entries, args.days, args.simulator_days, now))
        return 0

    stale = [e for e in entries if e.reason]
    total = sum(e.size_bytes for e in stale)

    free, total_disk = disk_usage()
    disk_line = f"Disk: {human_size(free)} free of {human_size(total_disk)}"
    interactive = bool(stale) and not args.dry_run and not args.yes

    if args.all:
        if not entries:
            print("No DerivedData or worktree build folders found.")
            print(disk_line)
            return 0
        print(render_table(entries, now))
        print(f"\n{len(entries)} folder(s), total {human_size(sum(e.size_bytes for e in entries))} "
              f"— {len(stale)} stale ({human_size(total)})")
        print(disk_line)
    else:
        if not stale:
            print("Nothing to clean.")
            print(disk_line)
            return 0
        print(render_table(stale, now, numbered=interactive))
        print(f"\n{len(stale)} folder(s), total {human_size(total)}")
        print(disk_line)

    if not stale or args.dry_run:
        return 0

    selected = stale
    if not args.yes:
        if args.all:
            print()
            print(render_table(stale, now, numbered=True))
        try:
            ans = input(
                "Delete which? [a]ll / [n]one / e.g. 1,3,5-7 (default none): "
            ).strip().lower()
        except EOFError:
            ans = ""
        if ans in ("", "n", "no", "none"):
            print("Aborted.")
            return 0
        if ans not in ("a", "all", "y", "yes"):
            idx = parse_selection(ans, len(stale))
            if idx is None:
                print("Invalid selection. Aborted.")
                return 0
            selected = [stale[i] for i in sorted(idx)]
            if not selected:
                print("Nothing selected. Aborted.")
                return 0

    freed = delete_entries(selected)
    free_after, total_after = disk_usage()
    print(f"\nFreed {human_size(freed)}. Disk: {human_size(free_after)} free of {human_size(total_after)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
